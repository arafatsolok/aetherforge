# =============================================================================
# AetherForge — environment template
# Copy to `.env` and fill every `CHANGE_ME`. Anything marked REQUIRED will
# cause `docker compose up` to fail at boot if unset (by design).
# =============================================================================

# ---------- General ----------------------------------------------------------
AETHERFORGE_ENV=development          # development | staging | production
AETHERFORGE_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
AETHERFORGE_DEFAULT_PERSONA=white    # white | gray | black
AETHERFORGE_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ---------- Auth gate (REQUIRED in production) -------------------------------
# When set, /api/v1/* requires the X-API-Key header and /ui/* requires a
# session cookie obtained via /ui/login. UNSET = development mode (NO AUTH —
# every request is accepted). Production validators reject placeholder /
# weak values; generate one with:  openssl rand -hex 32
#
# AETHERFORGE_API_KEY=CHANGE_ME_openssl_rand_hex_32

# Disable the CSRF middleware (NOT recommended). Default 1 = enabled.
# AETHERFORGE_CSRF_ENABLED=1

# Override the per-IP token-bucket rate limit. Default 60 req/min.
# AETHERFORGE_API_RATE_LIMIT=60

# ---------- API ---------------------------------------------------------------
API_PORT=8000
API_HOST=0.0.0.0
API_RELOAD=false                     # true for dev hot-reload
API_WORKERS=2

# Comma-separated origins for CORS. Empty = allow none.
API_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---------- Postgres (REQUIRED) ----------------------------------------------
POSTGRES_USER=aetherforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=aetherforge
POSTGRES_PORT=5432

# ---------- Redis (REQUIRED) -------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_PORT=6379

# ---------- Temporal ---------------------------------------------------------
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8088
TEMPORAL_NAMESPACE=aetherforge
TEMPORAL_TASK_QUEUE=aetherforge-main

# ---------- Worker -----------------------------------------------------------
WORKER_REPLICAS=2
WORKER_MAX_CONCURRENT_ACTIVITIES=20
WORKER_MAX_CONCURRENT_WORKFLOWS=50

# ---------- Metasploit RPC (REQUIRED when profile=exploit) -------------------
# In production the validator REJECTS values starting with "change-me" or
# shorter than 12 chars. Generate strong passwords here.
MSF_RPC_USER=aetherforge
MSF_RPC_PASS=CHANGE_ME_STRONG_MSF_PASSWORD
MSF_RPC_PORT=55553

# ---------- OpenVAS (REQUIRED when profile=scan) -----------------------------
OPENVAS_PASSWORD=CHANGE_ME_STRONG_OPENVAS_PASSWORD

# ---------- Wazuh (optional when profile=monitor) ----------------------------
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_STRONG_WAZUH_PASSWORD

# ---------- Tool execution sandbox -------------------------------------------
# Maximum wall-clock runtime (seconds) any single tool container may run.
TOOL_RUN_TIMEOUT=3600

# Per-tool cgroup memory cap (bytes). Default 1 GiB.
TOOL_MEMORY_LIMIT=1073741824

# CPU shares relative weight (1024 = default). Tool containers get half.
TOOL_CPU_SHARES=512

# Persona default rate-limit (requests/sec) applied to active scans.
TOOL_RATE_LIMIT_WHITE=2
TOOL_RATE_LIMIT_GRAY=20
TOOL_RATE_LIMIT_BLACK=100

# ---------- Safety / scope ----------------------------------------------------
# If true, orchestrator refuses any target not listed in configs/targets.yaml
STRICT_SCOPE_ENFORCEMENT=true

# Comma-separated CIDRs that are FORBIDDEN even if a YAML scope allows them.
# Internet-routable production ranges should be listed here.
FORBIDDEN_CIDRS=0.0.0.0/0

# ---------- Observability ----------------------------------------------------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
